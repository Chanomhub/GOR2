# Cloudflare R2 Configuration
# Copy this file to .env and fill in your actual credentials.

R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"

# The public URL of your R2 bucket
# e.g., https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL="https://pub-your-id.r2.dev"

# Backblaze B2 Configuration
B2_ACCOUNT_ID="your-b2-account-id"
B2_ACCESS_KEY_ID="your-b2-access-key-id"
B2_SECRET_ACCESS_KEY="your-b2-secret-access-key"
B2_BUCKET_NAME="your-b2-bucket-name"
B2_ENDPOINT="https://s3.us-west-004.backblazeb2.com"
B2_PUBLIC_URL="https://f004.backblazeb2.com/file/your-bucket-name"
